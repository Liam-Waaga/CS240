        //         node.right.parent = node;
        //     return top;
        // }


        // private static <X extends Comparable<X>> AVLNode<X> rotate_right(AVLNode<X> node) {
        //     AVLNode<X> top = node.left;
            
        //     node.left = node.left.right;
        //     top.right = node;
        //     top.parent = node.parent;
        //     if (node.parent != null) {
        //         if (node.parent.left == node) {
        //             top.parent.left = top;
        //         } else {
        //             top.parent.right = top;
        //         }
        //     }
        //     node.parent = top;
        //     if (node.left != null)
        //         node.left.parent = node;
        //     return top;
        // }

        private static <X extends Comparable<X>> AVLNode<X> rotate_left(AVLNode<X> node) {
            if (node == null) return null;
            AVLNode<X> top = node.right;
            if (top == null) return node; /* nothing to rotate */

            /* perform rotation */
            node.right = top.left;
            if (top.left != null) top.left.parent = node;

            top.left = node;

            /* reconnect parent of original node to top */
            top.parent = node.parent;
            if (node.parent != null) {
                if (node.parent.left == node) node.parent.left = top;
                else node.parent.right = top;
            }

            node.parent = top;

            return top;
        }

        private static <X extends Comparable<X>> AVLNode<X> rotate_right(AVLNode<X> node) {
            if (node == null) return null;
            AVLNode<X> top = node.left;
            if (top == null) return node; /* nothing to rotate */

            /* perform rotation */
            node.left = top.right;
            if (top.right != null) top.right.parent = node;

            top.right = node;

            // reconnect parent of original node to top
            top.parent = node.parent;
            if (node.parent != null) {
                if (node.parent.left == node) node.parent.left = top;
                else node.parent.right = top;
            }

            node.parent = top;

            return top;
        }
    }

    private AVLNode<T> root = null;

    public AVLTree() {}

    public void print() {
        root.print();
    }

    public void insert(T obj) {
        if (root == null) {
            root = new AVLNode<T>(obj, null, null, null);
        } else {

            AVLNode<T> curr = root;
            AVLNode<T> prev = curr;
            boolean left = false;
            while (curr != null) {
                prev = curr;
                if (curr.obj.compareTo(obj) < 0) {
                    curr = curr.right;
                    left = false;
                } else if (curr.obj.compareTo(obj) > 0) {
                    curr = curr.left;
                    left = true;
                } else {
                    throw new IllegalArgumentException();
                }
            }
            if (left) {
                prev.left = new AVLNode<T>(obj, null, null, prev);
            } else {
                prev.right = new AVLNode<T>(obj, null, null, prev);
            }

            while (true) {
                root.height();

                if (prev.balance_factor() > 1 && prev.left.obj.compareTo(obj) > 0) {
                    prev = AVLNode.rotate_left(prev);

                } else if (prev.balance_factor() < -1 && prev.right.obj.compareTo(obj) < 0) {
                    prev = AVLNode.rotate_right(prev);

                } else if (prev.balance_factor() > 1 && prev.left.obj.compareTo(obj) < 0) {
                    prev.left = AVLNode.rotate_left(prev.left);
                    prev = AVLNode.rotate_right(prev);

                } else if (prev.balance_factor() < -1 && prev.right.obj.compareTo(obj) > 0) {
                    prev.right = AVLNode.rotate_right(prev.right);
                    prev = AVLNode.rotate_left(prev);

                }
                if (prev.parent == null) {
                    root = prev;
                    break;
                }

                prev = prev.parent;
            }



        }
    }

    public T remove(T obj) {
        if (root == null) {
            throw new IllegalArgumentException();
        }

        return root.remove(obj);
    }
}
