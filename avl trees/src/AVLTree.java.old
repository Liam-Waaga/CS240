

public class AVLTree<T extends Comparable<T>> {
    
    public class AVLNode<E extends Comparable<E>> {

        protected E obj;

        protected AVLNode<E> left;
        protected AVLNode<E> right;
        protected AVLNode<E> parent;

        private int height = 0;

        public AVLNode(E obj, AVLNode<E> left, AVLNode<E> right, AVLNode<E> parent) {
            this.obj = obj;
            this.left = left;
            this.right = right;
            this.parent = parent;
        }

        public void print() {
            if (left != null) left.print();
            System.out.print(obj + ", ");
            if (right != null) right.print();
        }

        private int balance_factor() {
            int left_height = 0;
            int right_height = 0;

            if (left != null) {
                left_height = left.height;
            }

            if (right != null) {
                right_height = right.height;
            }

            return left_height - right_height;
        }

        public int height() {
            this.height = Math.max((left != null) ? left.height() : 0, (right != null) ? right.height() : 0) + 1;
            return this.height;
        }


        public E remove(E obj) {
            AVLNode<E> curr = this;
            boolean left = false;
            while (curr != null) {
                if (curr.obj.compareTo(obj) < 0) {
                    curr = curr.right;
                    left = false;
                } else if (curr.obj.compareTo(obj) > 0) {
                    curr = curr.left;
                    left = true;
                } else {
                    break;
                }
            }
            if (curr == null) {
                throw new IllegalArgumentException();
            }

            E removed = null;


            if (curr.right == null && curr.left == null) {
                if (left) {
                    curr.parent.left = null;
                } else {
                    curr.parent.right = null;
                }

                removed = curr.obj;
            } else if (curr.right != null && curr.left == null) {
                if (left) {
                    curr.parent.left = curr.right;
                } else {
                    curr.parent.right = curr.right;
                }
                curr.right.parent = curr.parent;

                removed = curr.obj;
            } else if (curr.right == null) {
                if (left) {
                    curr.parent.left = curr.left;
                } else {
                    curr.parent.right = curr.left;
                }
                curr.left.parent = curr.parent;

                removed = curr.obj;
            } else {
                AVLNode<E> min = curr.right;
                while (min.left != null) min = min.left;
                
                curr.left.parent = min;
                curr.right.parent = min;
                if (left) curr.parent.left = min;
                else curr.parent.right = min;

                
                min.left = curr.left;
                min.right = curr.right;
                
                removed = curr.obj;

                {
                    AVLNode<E> tmp = min.parent;
                    min.parent = curr.parent;
                    curr = tmp;
                }
            }


            while (curr != null) {
                curr.height();

                if (curr.balance_factor() > 1 && curr.left.balance_factor() >= 0) {
                    curr = rotate_right(curr);

                } else if (curr.balance_factor() < -1 && curr.right.balance_factor() <= 0) {
                    curr = rotate_left(curr);

                } else if (curr.balance_factor() > 1 && curr.left.balance_factor() < 0) {
                    curr.left = rotate_left(curr.left);
                    curr = rotate_right(curr);

                } else if (curr.balance_factor() < -1 && curr.right.balance_factor() > 0) {
                    curr.right = rotate_right(curr.right);
                    curr = rotate_left(curr);

                }

                curr = curr.parent;
            }
            return removed;
        }


        // private static <X extends Comparable<X>> AVLNode<X> rotate_left(AVLNode<X> node) {
        //     AVLNode<X> top = node.right;
            
        //     node.right = node.right.left;
        //     top.left = node;
        //     top.parent = node.parent;
        //     if (node.parent != null) {
